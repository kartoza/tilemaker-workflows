      "source-layer": "waterway",
      "paint": {
        "line-color": "#6b9dc2",
        "line-opacity": 0.75,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          8, 0.7,
          14, 2.5
        ]
      }
    },
    {
      "id": "boundary-country",
