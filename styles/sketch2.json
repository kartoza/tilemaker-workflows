{
  "version": 8,
  "name": "Sketch 2",
  "sources": {
    "planet": {
      "type": "vector",
      "tiles": ["/services/planet/tiles/{z}/{x}/{y}.pbf"],
      "minzoom": 0,
      "maxzoom": 14
    }
  },
  "glyphs": "/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f5ede0"
      }
    },
    {
      "id": "landcover-all",
      "type": "fill",
      "source": "planet",
      "source-layer": "landcover",
      "paint": {
        "fill-color": "#dde8cc",
        "fill-opacity": 0.3
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "planet",
      "source-layer": "landcover",
      "filter": [
        "any",
        ["==", "class", "wood"],
        ["==", "class", "forest"]
      ],
      "paint": {
        "fill-color": "#7da47d",
        "fill-opacity": 0.4
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "planet",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#a5c48a",
        "fill-opacity": 0.35
      }
    },
    {
      "id": "landcover-farmland",
      "type": "fill",
      "source": "planet",
      "source-layer": "landcover",
      "filter": ["==", "class", "farmland"],
      "paint": {
        "fill-color": "#d4c8a0",
        "fill-opacity": 0.3
      }
    },
    {
      "id": "landcover-wetland",
      "type": "fill",
      "source": "planet",
      "source-layer": "landcover",
      "filter": ["==", "class", "wetland"],
      "paint": {
        "fill-color": "#8cb8a8",
        "fill-opacity": 0.4
      }
    },
    {
