      "paint": {
        "fill-color": "#e8dfc0",
        "fill-opacity": 0.45
      }
    },
    {
      "id": "landcover-ice",
      "type": "fill",
      "source": "planet",
      "source-layer": "landcover",
      "filter": [
        "any",
        ["==", "subclass", "ice_shelf"],
        ["==", "subclass", "glacier"],
        ["==", "class", "ice"]
