{
  "version": 8,
  "name": "OSM",
  "metadata": {
    "maputnik:renderer": "mlgljs"
  },
  "sources": {
    "osm": {
      "type": "vector",
      "url": "/services/planet"
    }
  },
  "sprite": "/sprites/icons",
  "glyphs": "https://orangemug.github.io/font-glyphs/glyphs/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "water",
      "type": "fill",
      "source": "osm",
      "source-layer": "water",
      "filter": [
        "all",
        [
          "==",
          "class",
          "ocean"
        ]
      ],
      "paint": {
        "fill-color": "rgba(164, 253, 247, 1)"
      }
    },
    {
      "id": "rail-left",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "==",
          "class",
          "rail"
        ]
      ],
      "paint": {
        "line-offset": 3
      }
    },
    {
      "id": "rail-right",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation",
      "filter": [
        "all",
        [
          "==",
          "class",
          "rail"
        ]
      ],
      "paint": {
        "line-offset": 0
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "osm",
      "source-layer": "transportation"
    },
    {
      "id": "aerodrome-icon",
      "type": "symbol",
      "source": "planet",
      "source-layer": "aerodrome_label",
      "minzoom": 10,
      "layout": {
        "icon-image": "airport",
        "icon-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          10,
          0.5,
          14,
          0.8
        ],
        "text-field": [
          "coalesce",
          [
            "get",
            "name:latin"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 10,
        "text-offset": [
          0,
          1.5
        ],
        "text-anchor": "top",
        "text-optional": true
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 2,
        "icon-opacity": 0.85
      }
    },
    {
      "id": "mountain-peak-icon",
      "type": "symbol",
      "source": "planet",
      "source-layer": "mountain_peak",
      "minzoom": 11,
      "layout": {
        "icon-image": "mountain",
        "icon-size": [
          "interpolate",
          [
            "linear"
          ],
          [
            "zoom"
          ],
          11,
          0.5,
          14,
          0.7
        ],
        "text-field": [
          "concat",
          [
            "coalesce",
            [
              "get",
              "name:latin"
            ],
            [
              "get",
              "name"
            ]
          ],
          "\n",
          [
            "case",
            [
              "has",
              "ele"
            ],
            [
              "concat",
              [
                "get",
                "ele"
              ],
              "m"
            ],
            ""
          ]
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 10,
        "text-offset": [
          0,
          1.5
        ],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 2,
        "icon-opacity": 0.8
      }
    },
    {
      "id": "poi-icons",
      "type": "symbol",
      "source": "planet",
      "source-layer": "poi",
      "minzoom": 14,
      "filter": [
        "<=",
        "rank",
        5
      ],
      "layout": {
        "icon-image": [
          "match",
          [
            "get",
            "subclass"
          ],
          "restaurant",
          "restaurant",
          "cafe",
          "cafe",
          "bar",
          "bar",
          "pub",
          "beer",
          "fast_food",
          "fast-food",
          "hospital",
          "hospital",
          "clinic",
          "hospital",
          "pharmacy",
          "pharmacy",
          "school",
          "school",
          "university",
          "college",
          "library",
          "library",
          "museum",
          "museum",
          "theatre",
          "theatre",
          "cinema",
          "cinema",
          "place_of_worship",
          "place-of-worship",
          "bank",
          "bank",
          "post_office",
          "post",
          "police",
          "police",
          "fire_station",
          "fire-station",
          "fuel",
          "fuel",
          "parking",
          "parking",
          "supermarket",
          "grocery",
          "convenience",
          "convenience",
          "bakery",
          "bakery",
          "hotel",
          "lodging",
          "camp_site",
          "campsite",
          "swimming_pool",
          "swimming",
          "playground",
          "playground",
          "garden",
          "garden",
          "zoo",
          "zoo",
          "information",
          "information",
          "viewpoint",
          "viewpoint",
          "toilets",
          "toilet",
          "drinking_water",
          "drinking-water",
          "marker"
        ],
        "icon-size": 0.6,
        "text-field": [
          "coalesce",
          [
            "get",
            "name:latin"
          ],
          [
            "get",
            "name"
          ]
        ],
        "text-font": [
          "Noto Sans Regular"
        ],
        "text-size": 10,
        "text-offset": [
          0,
          1.3
        ],
        "text-anchor": "top",
        "text-optional": true
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255,255,255,0.9)",
        "text-halo-width": 2,
        "icon-opacity": 0.85
      }
    }
  ],
  "id": "4znnily"
}
